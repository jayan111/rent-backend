# ─── Database (MySQL) ──────────────────────────────────────────────────────────
# Railway auto-injects these when you add a MySQL plugin
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=rentyourneeds
DB_PORT=3306

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 64
JWT_SECRET=replace_with_64_char_random_string
JWT_REFRESH_SECRET=replace_with_another_64_char_random_string

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=production

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated, no trailing slash
ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-admin.vercel.app

# ─── Frontend URLs (used in password-reset and order emails) ──────────────────
FRONTEND_URL=https://your-frontend.vercel.app
ADMIN_URL=https://your-admin.vercel.app

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_SUCCESS_URL=https://your-frontend.vercel.app/checkout/success
STRIPE_CANCEL_URL=https://your-frontend.vercel.app/cart

# ─── Email / SMTP (Gmail App Password) ────────────────────────────────────────
# Gmail: 2FA → Google Account → Security → App Passwords → Mail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_16_char_app_password

# ─── Redis (optional) ──────────────────────────────────────────────────────────
# App works without Redis — add Railway Redis plugin if you want caching/queues
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=